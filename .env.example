# Public site URL — used for metadataBase, canonical URLs, and OG images.
NEXT_PUBLIC_SITE_URL=https://threshold-practices.app

# Supabase project (free tier) — powers the reflections feature (record/type a
# note after a practice). Without these, ReflectionCapture and Reflections both
# render nothing rather than erroring, so the site works fine without them too.
#
# Setup: create a project at https://supabase.com, run
# supabase/migrations/0001_reflections.sql in its SQL editor, then copy the
# Project URL and anon/public key from Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
